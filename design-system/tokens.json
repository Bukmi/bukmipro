{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "company": "Bukmi",
    "name": "Brightside",
    "version": "1.0.0",
    "description": "Brightside is Bukmi's design system — a dark-mode-first visual language built for a marketplace that connects artists with promoters. Named after the acid yellow-green accent that lights up every interface, Brightside keeps things sharp, accessible and fast: high-contrast surfaces, a single expressive brand colour, and zero decorative noise.",
    "mode": "dark",
    "url": "https://github.com/Bukmi/bukmipro/tree/claude/priceless-chebyshev-72e36d/design-system"
  },

  "color": {
    "graphite": {
      "$description": "Base background scale — near-black dark UI",
      "DEFAULT": { "$value": "#1F1F1F", "$type": "color" },
      "soft":    { "$value": "#262626", "$type": "color" },
      "line":    { "$value": "#333333", "$type": "color" }
    },
    "paper": {
      "$description": "Text / foreground scale",
      "DEFAULT": { "$value": "#F2F2F2", "$type": "color" },
      "dim":     { "$value": "#C9C9C9", "$type": "color" },
      "mute":    { "$value": "#8A8A8A", "$type": "color" }
    },
    "accent": {
      "$description": "Primary brand color — acid yellow-green",
      "DEFAULT": { "$value": "#E7FF52", "$type": "color" },
      "ink":     { "$value": "#1F1F1F", "$type": "color" }
    },
    "semantic": {
      "danger":  { "$value": "#FF6B6B", "$type": "color" },
      "success": { "$value": "#3DDC97", "$type": "color" }
    }
  },

  "typography": {
    "fontFamily": {
      "sans":    { "$value": "Inter, ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily" },
      "display": { "$value": "Inter, ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily" }
    },
    "fontFeatures": {
      "default": { "$value": "'ss01', 'cv11'", "$type": "other" }
    },
    "scale": {
      "display": {
        "$type": "typography",
        "$value": {
          "fontFamily": "Inter",
          "fontSize": "clamp(2.5rem, 6vw, 5rem)",
          "fontWeight": "800",
          "lineHeight": "1.02",
          "letterSpacing": "-0.03em"
        },
        "$description": "Hero headlines — landing page top section"
      },
      "hero": {
        "$type": "typography",
        "$value": {
          "fontFamily": "Inter",
          "fontSize": "clamp(2rem, 4vw, 3.25rem)",
          "fontWeight": "800",
          "lineHeight": "1.05",
          "letterSpacing": "-0.02em"
        },
        "$description": "Section headings — dashboard h1, page titles"
      },
      "xl": {
        "$type": "typography",
        "$value": {
          "fontFamily": "Inter",
          "fontSize": "1.25rem",
          "fontWeight": "700",
          "lineHeight": "1.4"
        }
      },
      "lg": {
        "$type": "typography",
        "$value": {
          "fontFamily": "Inter",
          "fontSize": "1.125rem",
          "fontWeight": "600",
          "lineHeight": "1.5"
        }
      },
      "base": {
        "$type": "typography",
        "$value": {
          "fontFamily": "Inter",
          "fontSize": "1rem",
          "fontWeight": "400",
          "lineHeight": "1.6"
        }
      },
      "sm": {
        "$type": "typography",
        "$value": {
          "fontFamily": "Inter",
          "fontSize": "0.875rem",
          "fontWeight": "400",
          "lineHeight": "1.5"
        }
      },
      "xs": {
        "$type": "typography",
        "$value": {
          "fontFamily": "Inter",
          "fontSize": "0.75rem",
          "fontWeight": "400",
          "lineHeight": "1.4",
          "letterSpacing": "0.02em"
        }
      },
      "label": {
        "$type": "typography",
        "$value": {
          "fontFamily": "Inter",
          "fontSize": "0.625rem",
          "fontWeight": "700",
          "lineHeight": "1",
          "letterSpacing": "0.2em",
          "textTransform": "uppercase"
        },
        "$description": "Used for eyebrow labels — 'Dashboard', 'Onboarding', section tags"
      }
    }
  },

  "spacing": {
    "0":   { "$value": "0px",    "$type": "dimension" },
    "0.5": { "$value": "2px",    "$type": "dimension" },
    "1":   { "$value": "4px",    "$type": "dimension" },
    "1.5": { "$value": "6px",    "$type": "dimension" },
    "2":   { "$value": "8px",    "$type": "dimension" },
    "3":   { "$value": "12px",   "$type": "dimension" },
    "4":   { "$value": "16px",   "$type": "dimension" },
    "5":   { "$value": "20px",   "$type": "dimension" },
    "6":   { "$value": "24px",   "$type": "dimension" },
    "8":   { "$value": "32px",   "$type": "dimension" },
    "10":  { "$value": "40px",   "$type": "dimension" },
    "12":  { "$value": "48px",   "$type": "dimension" },
    "16":  { "$value": "64px",   "$type": "dimension" },
    "20":  { "$value": "80px",   "$type": "dimension" },
    "24":  { "$value": "96px",   "$type": "dimension" }
  },

  "borderRadius": {
    "sm":   { "$value": "6px",   "$type": "borderRadius" },
    "md":   { "$value": "8px",   "$type": "borderRadius" },
    "lg":   { "$value": "10px",  "$type": "borderRadius" },
    "xl":   { "$value": "14px",  "$type": "borderRadius", "$description": "Default interactive elements" },
    "2xl":  { "$value": "20px",  "$type": "borderRadius", "$description": "Cards, panels" },
    "full": { "$value": "9999px","$type": "borderRadius", "$description": "Pills, badges" }
  },

  "border": {
    "default": {
      "$value": {
        "width": "1px",
        "style": "solid",
        "color": "#333333"
      },
      "$type": "border",
      "$description": "Standard divider — graphite-line"
    },
    "accent": {
      "$value": {
        "width": "2px",
        "style": "solid",
        "color": "#E7FF52"
      },
      "$type": "border"
    }
  },

  "animation": {
    "duration": {
      "fast":    { "$value": "150ms", "$type": "duration" },
      "default": { "$value": "250ms", "$type": "duration" },
      "slow":    { "$value": "400ms", "$type": "duration" }
    },
    "easing": {
      "default":  { "$value": "ease-out",  "$type": "cubicBezier" },
      "spring":   { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
    },
    "keyframes": {
      "fade-up": {
        "$description": "Entry animation — opacity 0→1 + translateY 8px→0, 400ms ease-out",
        "$type": "other",
        "$value": "fade-up 400ms ease-out both"
      }
    }
  },

  "focus": {
    "ring": {
      "$description": "WCAG 2.1 AA focus ring — applied globally via *:focus-visible",
      "$type": "other",
      "$value": "2px solid #E7FF52, offset 2px, offset-color #1F1F1F"
    }
  },

  "layout": {
    "containerHero": {
      "$value": "max-width: 1280px, padding: 0 24px, margin: 0 auto",
      "$type": "other",
      "$description": ".container-hero — main page wrapper"
    },
    "containerContent": {
      "$value": "max-width: 768px (prose), max-width: 1280px (full)",
      "$type": "other"
    }
  },

  "component": {
    "button": {
      "$description": "rounded-xl, font-bold, text-sm, transition-colors, focus ring",
      "height": {
        "sm": { "$value": "36px", "$type": "dimension" },
        "md": { "$value": "44px", "$type": "dimension" },
        "lg": { "$value": "48px", "$type": "dimension" },
        "icon": { "$value": "40px", "$type": "dimension" }
      },
      "variant": {
        "primary": {
          "$description": "bg-accent text-accent-ink hover:bg-accent/90",
          "$type": "other",
          "$value": "background: #E7FF52, color: #1F1F1F, hover: #E7FF52 at 90% opacity"
        },
        "secondary": {
          "$description": "bg-paper text-graphite hover:bg-paper-dim",
          "$type": "other",
          "$value": "background: #F2F2F2, color: #1F1F1F, hover: #C9C9C9"
        },
        "ghost": {
          "$description": "bg-transparent text-paper hover:bg-graphite-soft",
          "$type": "other",
          "$value": "background: transparent, color: #F2F2F2, hover: #262626"
        },
        "outline": {
          "$description": "border border-paper/30 text-paper hover:bg-graphite-soft",
          "$type": "other",
          "$value": "border: 1px solid rgba(242,242,242,0.3), color: #F2F2F2"
        },
        "link": {
          "$description": "underline underline-offset-4 text-paper hover:text-accent px-0",
          "$type": "other",
          "$value": "no background, underline, hover: #E7FF52"
        },
        "danger": {
          "$description": "bg-danger text-graphite hover:bg-danger/90",
          "$type": "other",
          "$value": "background: #FF6B6B, color: #1F1F1F"
        }
      }
    },
    "input": {
      "$description": "h-11, rounded-xl, border-graphite-line, bg-graphite-soft, focus ring accent",
      "height":       { "$value": "44px",    "$type": "dimension" },
      "paddingX":     { "$value": "16px",    "$type": "dimension" },
      "borderRadius": { "$value": "14px",    "$type": "borderRadius" },
      "borderColor":  { "$value": "#333333", "$type": "color" },
      "background":   { "$value": "#262626", "$type": "color" },
      "textColor":    { "$value": "#F2F2F2", "$type": "color" },
      "placeholderColor": { "$value": "#8A8A8A", "$type": "color" },
      "errorBorderColor": { "$value": "#FF6B6B", "$type": "color" }
    },
    "textarea": {
      "$description": "Same as input but min-h-[120px], py-3",
      "minHeight":    { "$value": "120px",   "$type": "dimension" },
      "paddingY":     { "$value": "12px",    "$type": "dimension" }
    },
    "card": {
      "$description": "rounded-2xl bg-graphite-soft ring-1 ring-graphite-line — standard panel",
      "borderRadius": { "$value": "20px",    "$type": "borderRadius" },
      "background":   { "$value": "#262626", "$type": "color" },
      "border":       { "$value": "#333333", "$type": "color" },
      "padding":      { "$value": "24px",    "$type": "dimension" }
    },
    "badge": {
      "$description": "rounded-full px-2 py-1 text-[10px] font-bold uppercase tracking-wide",
      "paddingX":     { "$value": "8px",     "$type": "dimension" },
      "paddingY":     { "$value": "4px",     "$type": "dimension" },
      "fontSize":     { "$value": "10px",    "$type": "dimension" },
      "borderRadius": { "$value": "9999px",  "$type": "borderRadius" },
      "variant": {
        "accent":   { "$value": "background: rgba(231,255,82,0.2), color: #E7FF52", "$type": "other" },
        "neutral":  { "$value": "background: #333333, color: #C9C9C9",              "$type": "other" },
        "danger":   { "$value": "background: rgba(255,107,107,0.15), color: #FF6B6B", "$type": "other" },
        "success":  { "$value": "background: rgba(61,220,151,0.15), color: #3DDC97", "$type": "other" }
      }
    },
    "label": {
      "$description": "text-sm font-semibold text-paper",
      "fontSize":     { "$value": "0.875rem", "$type": "dimension" },
      "fontWeight":   { "$value": "600",      "$type": "other" },
      "color":        { "$value": "#F2F2F2",  "$type": "color" }
    },
    "field": {
      "$description": "Wrapper: flex flex-col gap-2. Pairs Label + Input + hint/error text.",
      "gap":          { "$value": "8px",     "$type": "dimension" },
      "hintColor":    { "$value": "#C9C9C9", "$type": "color" },
      "errorColor":   { "$value": "#FF6B6B", "$type": "color" }
    },
    "progressBar": {
      "$description": "StepProgress — h-2 rounded-full bg-graphite-line, indicator bg-accent, animated width",
      "height":       { "$value": "8px",     "$type": "dimension" },
      "background":   { "$value": "#333333", "$type": "color" },
      "fill":         { "$value": "#E7FF52", "$type": "color" },
      "borderRadius": { "$value": "9999px",  "$type": "borderRadius" },
      "transition":   { "$value": "width 500ms ease-out", "$type": "other" }
    },
    "divider": {
      "$description": ".ink-divider — h-px w-full bg-graphite-line",
      "height":       { "$value": "1px",     "$type": "dimension" },
      "color":        { "$value": "#333333", "$type": "color" }
    },
    "skipLink": {
      "$description": "sr-only focus:not-sr-only — top-3 left-3 z-50, bg-accent text-accent-ink",
      "$type": "other",
      "$value": "Accessible skip-to-content, visually hidden until focused"
    }
  },

  "semantic": {
    "$description": "Role-based aliases — what each color means, not what it is",
    "surface": {
      "base":    { "$value": "#1F1F1F", "$type": "color", "$description": "Page background" },
      "raised":  { "$value": "#262626", "$type": "color", "$description": "Cards, panels" },
      "overlay": { "$value": "#333333", "$type": "color", "$description": "Borders, dividers, hover states" }
    },
    "text": {
      "primary":   { "$value": "#F2F2F2", "$type": "color", "$description": "Headings, labels, high-contrast body" },
      "secondary": { "$value": "#C9C9C9", "$type": "color", "$description": "Body text, descriptions" },
      "tertiary":  { "$value": "#8A8A8A", "$type": "color", "$description": "Hints, placeholders, disabled" }
    },
    "brand": {
      "primary":   { "$value": "#E7FF52", "$type": "color", "$description": "CTAs, active states, focus rings, accent" },
      "onPrimary": { "$value": "#1F1F1F", "$type": "color", "$description": "Text on accent background" }
    },
    "feedback": {
      "error":   { "$value": "#FF6B6B", "$type": "color" },
      "success": { "$value": "#3DDC97", "$type": "color" }
    }
  }
}
