// Bukmi — Prisma schema (Sprint 1 baseline)
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ARTIST
  PROMOTER
  OFFICE
  ADMIN
}

enum FormatType {
  SOLO
  BAND
  DJ
}

enum CompanyType {
  VENUE
  FESTIVAL
  AGENCY
  OFFICE
}

enum PlanCode {
  FREE
  ARTIST
  PRO
  OFFICE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MediaKind {
  PHOTO
  VIDEO
  TRACK
}

enum RiderKind {
  TECHNICAL
  HOSPITALITY
  STAGE_PLOT
}

enum AvailabilityStatus {
  FREE
  TENTATIVE
  BLOCKED
  BOOKED
}

enum ProposalStatus {
  INQUIRY
  NEGOTIATING
  ACCEPTED
  REJECTED
  BOOKED
  CANCELLED
}

enum MessageSender {
  PROMOTER
  ARTIST
  SYSTEM
}

enum CastingStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String?
  role              UserRole
  locale            String             @default("es")
  emailVerifiedAt   DateTime?
  planCode          PlanCode           @default(FREE)
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  trialEndsAt       DateTime?
  onboardingStatus  OnboardingStatus   @default(NOT_STARTED)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  suspendedAt       DateTime?

  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  stripePriceId         String?
  currentPeriodEnd      DateTime?

  artistProfile     ArtistProfile?
  promoterProfile   PromoterProfile?
  verificationTokens VerificationToken[]
  sessions          Session[]
  accounts          Account[]
  notifications     Notification[]
}

enum NotificationType {
  PROPOSAL_CREATED
  PROPOSAL_STATUS
  NEW_MESSAGE
  REVIEW_RECEIVED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model ArtistProfile {
  id                 String     @id @default(cuid())
  userId             String     @unique
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  stageName          String
  slug               String     @unique
  bio                String?
  genres             String[]   @default([])
  formatType         FormatType @default(SOLO)
  baseCity           String?
  radiusKm           Int?       @default(150)
  cacheMin           Int?
  cacheMax           Int?
  currency           String     @default("EUR")
  spotifyUrl         String?
  youtubeUrl         String?
  instagramUrl       String?
  soundcloudUrl      String?
  completenessScore  Int        @default(0)
  aiGenerated        Boolean    @default(false)
  published          Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  media                Media[]
  riders               Rider[]
  availability         Availability[]
  proposals            BookingRequest[]
  representedBy        ArtistRepresentation[]
  views                ProfileView[]
  castingApplications  CastingApplication[]
}

model ProfileView {
  id              String        @id @default(cuid())
  artistProfileId String
  artistProfile   ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  referer         String?
  source          String?
  createdAt       DateTime      @default(now())

  @@index([artistProfileId, createdAt])
}

model Media {
  id              String        @id @default(cuid())
  artistProfileId String
  artistProfile   ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  kind            MediaKind
  url             String
  caption         String?
  mimeType        String?
  sizeBytes       Int?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())

  @@index([artistProfileId, sortOrder])
}

model Rider {
  id              String        @id @default(cuid())
  artistProfileId String
  artistProfile   ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  kind            RiderKind     @default(TECHNICAL)
  label           String
  url             String
  mimeType        String?
  sizeBytes       Int?
  version         Int           @default(1)
  createdAt       DateTime      @default(now())

  @@index([artistProfileId, kind])
}

model Availability {
  id              String             @id @default(cuid())
  artistProfileId String
  artistProfile   ArtistProfile      @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  date            DateTime           @db.Date
  status          AvailabilityStatus
  note            String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([artistProfileId, date])
  @@index([date, status])
}

model PromoterProfile {
  id           String      @id @default(cuid())
  userId       String      @unique
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  cif          String?
  companyType  CompanyType @default(VENUE)
  contactEmail String?
  phone        String?
  verified     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  venues        Venue[]
  proposals     BookingRequest[]
  roster        ArtistRepresentation[]
  castingCalls  CastingCall[]
}

model ArtistRepresentation {
  id              String          @id @default(cuid())
  promoterId      String
  promoter        PromoterProfile @relation(fields: [promoterId], references: [id], onDelete: Cascade)
  artistProfileId String
  artistProfile   ArtistProfile   @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  note            String?
  createdAt       DateTime        @default(now())

  @@unique([promoterId, artistProfileId])
  @@index([promoterId])
}

model Venue {
  id             String          @id @default(cuid())
  promoterId     String
  promoter       PromoterProfile @relation(fields: [promoterId], references: [id], onDelete: Cascade)
  name           String
  city           String
  capacity       Int
  venueType      String          @default("sala")
  defaultGenres  String[]        @default([])
  createdAt      DateTime        @default(now())
  proposals      BookingRequest[]
}

model BookingRequest {
  id              String          @id @default(cuid())
  promoterId      String
  promoter        PromoterProfile @relation(fields: [promoterId], references: [id], onDelete: Cascade)
  artistProfileId String
  artistProfile   ArtistProfile   @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  venueId         String?
  venue           Venue?          @relation(fields: [venueId], references: [id], onDelete: SetNull)

  eventDate       DateTime        @db.Date
  eventCity       String
  venueName       String
  budgetMin       Int?
  budgetMax       Int?
  currency        String          @default("EUR")
  slot            String?
  notes           String?

  status          ProposalStatus  @default(INQUIRY)
  lastActivityAt  DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  messages        Message[]
  reviews         BookingReview[]

  @@index([artistProfileId, status])
  @@index([promoterId, status])
  @@index([eventDate])
}

model Message {
  id             String         @id @default(cuid())
  bookingId      String
  booking        BookingRequest @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender         MessageSender
  authorUserId   String?
  body           String
  createdAt      DateTime       @default(now())

  @@index([bookingId, createdAt])
}

enum ReviewPerspective {
  ARTIST
  PROMOTER
}

model BookingReview {
  id          String            @id @default(cuid())
  bookingId   String
  booking     BookingRequest    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  perspective ReviewPerspective
  authorUserId String
  rating      Int
  body        String?
  hiddenAt    DateTime?
  createdAt   DateTime          @default(now())

  @@unique([bookingId, perspective])
  @@index([bookingId])
}

model CastingCall {
  id             String          @id @default(cuid())
  promoterId     String
  promoter       PromoterProfile @relation(fields: [promoterId], references: [id], onDelete: Cascade)
  title          String
  venueName      String
  venueCity      String
  eventDate      DateTime        @db.Date
  formatType     FormatType?
  estimatedCache Int?
  currency       String          @default("EUR")
  description    String?
  applyDeadline  DateTime
  status         CastingStatus   @default(OPEN)
  applications   CastingApplication[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status, applyDeadline])
  @@index([promoterId])
}

model CastingApplication {
  id              String            @id @default(cuid())
  castingCallId   String
  castingCall     CastingCall       @relation(fields: [castingCallId], references: [id], onDelete: Cascade)
  artistProfileId String
  artistProfile   ArtistProfile     @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  status          ApplicationStatus @default(PENDING)
  message         String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([castingCallId, artistProfileId])
  @@index([artistProfileId])
}

// NextAuth tables (Prisma adapter minimal set)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  usedAt     DateTime?
  purpose    String?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([identifier, token])
}
