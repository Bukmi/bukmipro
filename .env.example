# =============================================================================
# Bukmi — Environment variables
# =============================================================================
# Copia este archivo a `.env.local` para desarrollo local.
# En Vercel, cada variable se configura en Settings → Environment Variables,
# con el scope correspondiente (Production / Preview / Development).
#
# Entornos:
#   - Local dev   → .env.local                → Supabase "Bukmi Pro"   (compartido con staging)
#   - Staging     → Vercel (branch: staging)  → Supabase "Bukmi Pro"
#   - Producción  → Vercel (branch: main)     → Supabase "Bukmi Prod"
# =============================================================================

# --- Base de datos (Supabase) ------------------------------------------------
# Usa el connection string del pooler (puerto 6543) con pgbouncer=true.
# En local, cópialo desde Supabase → Project Settings → Database → Connection string → URI.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# --- NextAuth ----------------------------------------------------------------
# Genera uno distinto por entorno: `openssl rand -base64 32`
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# URL pública del entorno
#   local      → http://localhost:3000
#   staging    → https://staging.bukmi.pro
#   producción → https://bukmi.pro
AUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# --- Email (Resend) ----------------------------------------------------------
# Si RESEND_API_KEY está vacío, los emails se logan en consola (dev-mode).
EMAIL_FROM="Bukmi <no-reply@bukmi.pro>"
RESEND_API_KEY=""

# --- Stripe ------------------------------------------------------------------
# Si STRIPE_SECRET_KEY está vacío, el checkout cae en dev-mode (activa plan directo).
# En staging usar test keys (sk_test_...). En producción, live keys (sk_live_...).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ARTIST=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_OFFICE=""

# --- Spotify (onboarding rápido de artistas) ---------------------------------
# Crea una app en dashboard.spotify.com → "Create App". No se necesita OAuth de usuario,
# solo Client Credentials (lectura de datos públicos).
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# --- Bio enrichment ----------------------------------------------------------
# Last.fm: gratis, registro inmediato en last.fm/api/account/create
LASTFM_API_KEY=""
# Google Knowledge Graph: console.cloud.google.com → habilitar "Knowledge Graph Search API"
# Free tier: 100.000 req/día
GOOGLE_KG_API_KEY=""
